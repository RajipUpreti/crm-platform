                "security": [
                    {
                        "CookieAuth": []
                    }
                ],
                "description": "Returns active tenant memberships for the authenticated user.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Tenants"
                ],
                "summary": "List available tenants",
                "responses": {
                    "200": {
