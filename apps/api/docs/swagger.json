        "/api/v1/tenants/{tenantId}/switch": {
            "post": {
                "security": [
                    {
                        "CookieAuth": []
                    }
                ],
                "description": "Validates active membership, rotates the application session, and selects the requested tenant.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Tenants"
                ],
                "summary": "Switch current tenant",
                "parameters": [
                    {
                        "type": "string",
                        "format": "uuid",
                        "description": "Tenant ID",
                        "name": "tenantId",
                        "in": "path",
                        "required": true
